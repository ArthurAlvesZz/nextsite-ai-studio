rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "arthurfgalves@gmail.com") ||
        (request.auth.token.email == "15599873676@nextcreatives.co") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isEditor() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    function isAdminOrEditor() {
      return isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOwnerOfDoc() {
      let docUserId = resource != null ? resource.data.get('userId', null) : null;
      let reqUserId = request.resource != null ? request.resource.data.get('userId', null) : null;
      
      return (request.method == 'create' && (reqUserId == request.auth.uid || reqUserId == null)) ||
             (request.method == 'update' && (docUserId == request.auth.uid || docUserId == null) && (reqUserId == request.auth.uid || reqUserId == docUserId || reqUserId == null)) ||
             (request.method == 'delete' && (docUserId == request.auth.uid || docUserId == null)) ||
             ((request.method == 'get' || request.method == 'list') && (docUserId == request.auth.uid || docUserId == null));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /settings/{settingId} {
      // Anyone can read the settings (it's the public landing page)
      allow read: if true;
      // Only admins can update settings
      allow write: if isAdmin() && (settingId == 'global' || settingId == request.auth.uid);
    }
    
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Only admins can create or update users
      allow write: if isAdmin();
    }
    
    match /leadsColhidos/{leadId} {
      // Only admins and editors can read and write leads
      allow read, write: if isAdminOrEditor() && isOwnerOfDoc();
    }
    
    match /dorks/{dorkId} {
      // Only admins can read and write dorks
      allow read, write: if isAdmin();
    }

    match /clients/{clientId} {
      // Admins and editors can read and write clients
      allow read, write: if isAdminOrEditor() && isOwnerOfDoc();
    }

    match /sales/{saleId} {
      // Admins and editors can read and write sales
      allow read, write: if isAdminOrEditor() && isOwnerOfDoc();
    }

    match /demands/{demandId} {
      // Admins and editors can read and write demands
      allow read, write: if isAdminOrEditor() && isOwnerOfDoc();
    }

    match /employees/{employeeId} {
      // Anyone can read (to show in lists), but only admins can write
      allow read: if isAuthenticated() && isOwnerOfDoc();
      allow write: if isAdmin() && isOwnerOfDoc();
    }

    match /goals/{goalId} {
      // Admins and editors can read goals, only admins can update
      allow read: if isAdminOrEditor();
      allow write: if isAdmin() && (goalId == 'global' || goalId == request.auth.uid);
    }
    
    match /presence/{sessionId} {
      // Anyone can read and write presence to show online users
      allow read, write: if true;
    }
  }
}
