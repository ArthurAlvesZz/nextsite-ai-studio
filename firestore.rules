rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS — Role Hierarchy
    //
    //  owner  →  isOwnerRole()       Controla tudo: settings, users,
    //                                employees, dorks, goals, billing
    //
    //  admin  →  isAdmin()           Inclui owner + role:'admin'.
    //                                Acesso operacional pleno.
    //
    //  editor →  isEditor()          Vendedores: acesso restrito aos
    //                                próprios dados, leads e clientes.
    //
    // ================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Owner: identidade verificada via e-mail hardcoded OU flag isOwner
    // no documento employees. É a identidade mais privilegiada do sistema.
    function isOwnerRole() {
      return isAuthenticated() && (
        request.auth.token.email == "arthurfgalves@gmail.com" ||
        request.auth.token.email == "15599873676@nextcreatives.co" ||
        (
          exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.isOwner == true
        )
      );
    }

    // Alias mantido para compatibilidade com regras existentes
    function isMasterOwner() {
      return isOwnerRole();
    }

    function isAdmin() {
      return isOwnerRole() || (
        isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isEditor() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor';
    }

    function isAdminOrEditor() {
      return isAdmin() || isEditor();
    }

    // Verifica se o UID do token corresponde ao userId do documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ================================================================
    // SETTINGS — Configurações da agência e dados da landing page
    //
    // Leitura: 'global' é pública (landing page). TODOS os outros docs
    //          são exclusivos do owner — nem admin/editor acessa.
    // ESCRITA: somente owner.
    // ================================================================
    match /settings/{settingId} {
      allow read:  if settingId == 'global' || isOwnerRole();
      allow write: if isOwnerRole();
    }

    // ================================================================
    // USERS — Perfis de autenticação (admin, editor)
    //
    // Leitura: cada usuário lê o próprio doc; owner lê todos.
    // ESCRITA: exclusivo do owner. Impede auto-promoção de role.
    // ================================================================
    match /users/{userId} {
      allow get:  if isOwner(userId) || isAdmin();
      allow list: if isOwnerRole();

      allow create: if isOwnerRole();

      // Owner pode atualizar qualquer campo, exceto remover a própria role de owner
      allow update: if isOwnerRole() && (
        resource.data.role != 'owner' ||
        request.resource.data.role == 'owner'
      );

      // Owner pode deletar, mas não o próprio documento
      allow delete: if isOwnerRole() && request.auth.uid != userId;
    }

    // ================================================================
    // EMPLOYEES — Membros da equipe (lista de funcionários)
    //
    // Leitura ampla (list): somente owner e admin.
    // Leitura própria (get): qualquer autenticado pode ler o próprio doc.
    // ESCRITA (create/delete): exclusivo do owner.
    // UPDATE: owner pode tudo; editor pode atualizar APENAS o próprio doc
    //         em campos não-sensíveis (avatar, telefone).
    // ================================================================
    match /employees/{employeeId} {
      allow get:  if isAdmin() || (isAuthenticated() && request.auth.uid == employeeId);
      allow list: if isAdmin();

      // Somente owner cria e deleta membros
      allow create: if isOwnerRole();
      allow delete: if isOwnerRole() && resource.data.isOwner != true;

      // Owner edita tudo. Editor edita apenas o próprio doc e apenas
      // campos permitidos (não pode alterar role, isOwner, userId, createdBy).
      allow update: if isOwnerRole() ||
        (
          isAdminOrEditor() &&
          request.auth.uid == employeeId &&
          !request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasAny(['isOwner', 'role', 'userId', 'createdBy', 'login'])
        );
    }

    // ================================================================
    // DORKS — Termos de busca para captura de leads (sensível)
    //
    // Acesso total exclusivo do owner. Editores não têm visibilidade.
    // ================================================================
    match /dorks/{dorkId} {
      allow read, write: if isOwnerRole();
    }

    // ================================================================
    // GOALS — Metas mensais da agência e individuais por membro
    //
    // Leitura: admin e editor (necessário para o dashboard).
    // ESCRITA: somente owner define metas.
    // ================================================================
    match /goals/{goalId} {
      allow read: if isAdminOrEditor();
      allow write: if isOwnerRole();
    }

    // ================================================================
    // CLIENTS — Clientes da agência
    //
    // Admin/editor: acesso pleno (operacional).
    // Cliente externo: pode ler apenas o próprio documento.
    // ================================================================
    match /clients/{clientId} {
      allow read: if isAdminOrEditor() ||
        (isAuthenticated() && (
          resource.data.accessId == request.auth.token.email.split('@')[0] ||
          clientId == request.auth.uid
        ));
      allow write: if isAdminOrEditor();
    }

    // ================================================================
    // SALES — Registros de vendas
    //
    // Leitura: admin/editor vê tudo; cliente lê própria venda.
    // ESCRITA: admin/editor.
    // ================================================================
    match /sales/{saleId} {
      allow read: if isAdminOrEditor() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdminOrEditor();
    }

    // ================================================================
    // DEMANDS — Demandas de produção de vídeo
    // ================================================================
    match /demands/{demandId} {
      allow read: if isAdminOrEditor() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdminOrEditor();
    }

    // ================================================================
    // NOTIFICATIONS — Notificações de clientes
    // ================================================================
    match /notifications/{notificationId} {
      allow read: if isAdminOrEditor() ||
        (isAuthenticated() && resource.data.clientId == request.auth.uid);
      // Cliente pode marcar a própria notificação como lida (apenas campo 'read')
      allow update: if isAuthenticated() &&
        resource.data.clientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if isAdminOrEditor();
    }

    // ================================================================
    // LEADS COLHIDOS — Pipeline de prospecção
    //
    // Owner: vê e gerencia todos os leads.
    // Admin: vê e gerencia todos os leads (acesso operacional pleno).
    // Editor/Vendedor: vê e trabalha APENAS os leads atribuídos a ele
    //                  (ownerId == uid). Não lista leads de outros.
    // ================================================================
    match /leadsColhidos/{leadId} {
      allow get: if isAdmin() ||
        (isEditor() && resource.data.ownerId == request.auth.uid);

      allow list: if isAdmin() ||
        (isEditor() && resource.data.ownerId == request.auth.uid);

      allow create: if isAdminOrEditor() &&
        (!('ownerId' in request.resource.data) ||
          request.resource.data.ownerId == request.auth.uid);

      allow update, delete: if isAdmin() ||
        (isEditor() && resource.data.ownerId == request.auth.uid);
    }

    // ================================================================
    // PRESENCE — Presença online em tempo real
    // ================================================================
    match /presence/{sessionId} {
      allow read:   if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        request.auth.uid == resource.data.uid;
    }

    // ================================================================
    // WHATSAPP SESSIONS — Sessões do bot WhatsApp (isolamento por UID)
    // ================================================================
    match /whatsapp_sessions/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();

      match /keys/{keyId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ================================================================
    // VIDEO PIPELINE RUNS — Logs de execução do pipeline de vídeo
    // Ferramenta exclusiva do owner. Admin/editor não tem acesso.
    // ================================================================
    match /videoPipelineRuns/{runId} {
      allow read, write: if isOwnerRole();
    }

    // ================================================================
    // SCRAPER METADATA — Status e progresso do scraper de leads
    // Leitura e escrita: somente owner (ferramenta de prospecção).
    // Escrita direta do cliente bloqueada — usa Admin SDK no servidor.
    // ================================================================
    match /scraper_metadata/{docId} {
      allow read:  if isOwnerRole();
      allow write: if false;
    }

    // ================================================================
    // RATE LIMITS — Controle de quota por usuário
    // Escrito exclusivamente pelo servidor via Admin SDK.
    // Bloqueado do lado do cliente para impedir manipulação.
    // ================================================================
    match /rateLimits/{userId} {
      allow read, write: if false;
    }

    // ================================================================
    // AI SYSTEM LOGS — Logs de erro do frontend e do servidor
    // Escrita permitida para capturar erros de sessões não autenticadas.
    // Leitura PERMANENTEMENTE bloqueada do cliente.
    // ================================================================
    match /ai_system_logs/{logId} {
      allow write: if true;
      allow read:  if false;
    }
  }
}
