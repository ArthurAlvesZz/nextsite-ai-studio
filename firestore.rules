rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isMasterOwner() {
      return isAuthenticated() && (
        (request.auth.token.email == "arthurfgalves@gmail.com") ||
        (request.auth.token.email == "15599873676@nextcreatives.co") ||
        (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.isOwner == true)
      );
    }

    function isAdmin() {
      return isMasterOwner() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isEditor() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor'
      );
    }

    function isAdminOrEditor() {
      return isAdmin() || isEditor();
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /settings/{settingId} {
      // Anyone can read the settings (it's the public landing page)
      allow read: if true;
      // Only admins can update settings
      allow write: if isAdmin() && (settingId == 'global' || settingId == request.auth.uid);
    }
    
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Prevent deleting the owner document
      allow delete: if isAdmin() && resource.data.role != 'admin' && resource.data.name != 'Arthur Fagundes #Owner';
      
      // Prevent demoting the owner
      allow update: if isAdmin() && (
        resource.data.role != 'admin' || 
        request.resource.data.role == 'admin'
      );
      
      allow create: if isAdmin();
    }
    
    match /leadsColhidos/{leadId} {
      // Only admins and editors can read and write leads
      allow read, write: if isAdminOrEditor();
    }
    
    match /dorks/{dorkId} {
      // Only admins can read and write dorks
      allow read, write: if isAdmin();
    }

    match /clients/{clientId} {
      // Admins and editors can read and write clients
      // Clients can read their own document
      allow read: if isAdminOrEditor() || (isAuthenticated() && (resource.data.accessId == request.auth.token.email.split('@')[0] || clientId == request.auth.uid));
      allow write: if isAdminOrEditor();
    }

    match /sales/{saleId} {
      // Admins and editors can read and write sales
      // Clients can read their own sales
      allow read: if isAdminOrEditor() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdminOrEditor();
    }

    match /demands/{demandId} {
      // Admins and editors can read and write demands
      // Clients can read their own demands
      allow read: if isAdminOrEditor() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdminOrEditor();
    }

    match /notifications/{notificationId} {
      // Clients can read and update their own notifications
      // Admins can read and write all
      allow read: if isAdminOrEditor() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.clientId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if isAdminOrEditor();
    }

    match /employees/{employeeId} {
      // Anyone can read (to show in lists), but only admins can write
      allow read: if isAuthenticated();
      
      // Prevent deleting the owner document
      allow delete: if isAdmin() && resource.data.isOwner != true;
      
      // Prevent modifying the isOwner flag or role of the owner
      allow update: if isAdmin() && (
        resource.data.isOwner != true || 
        (request.resource.data.isOwner == true && request.resource.data.role == 'Admin')
      );
      
      allow create: if isAdmin();
    }

    match /goals/{goalId} {
      // Admins and editors can read goals, only admins can update
      allow read: if isAdminOrEditor();
      allow write: if isAdmin() && (goalId == 'global' || goalId == request.auth.uid);
    }
    
    match /presence/{sessionId} {
      // Only authenticated users can read/write presence (prevents unauthenticated flood)
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow create: if isAuthenticated();
    }
  }
}
