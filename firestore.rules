rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "arthurfgalves@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "15599873676@nextcreatives.co") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /settings/{settingId} {
      // Anyone can read the settings (it's the public landing page)
      allow read: if true;
      // Only admins can update settings
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // Only admins can create or update users
      allow write: if isAdmin();
    }
    
    match /leads/{leadId} {
      // Only admins can read and write leads
      allow read, write: if isAdmin();
    }
    
    match /dorks/{dorkId} {
      // Only admins can read and write dorks
      allow read, write: if isAdmin();
    }
  }
}
