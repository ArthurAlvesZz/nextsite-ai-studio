{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|.*\\.(?:ico|png|jpg|jpeg|svg|js|css|gif|mp4|webm|woff2?)).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/buscar-leads",
      "schedule": "0 0 * * *"
    }
  ]
}
