# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# ─── Google AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ─── Google Custom Search ──────────────────────────────────────────────────────
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# ─── Groq Cloud API Key ────────────────────────────────────────────────────────
# Groq Cloud API Key (for Whisper transcription)
GROQ_API_KEY=

# ─── Google Custom Search ──────────────────────────────────────────────────────
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# ─── SMTP — Hostinger ─────────────────────────────────────────────────────────
# Used for password recovery emails.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM_NAME=Next Creative

# ─── Firebase Admin ───────────────────────────────────────────────────────────
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON,
# OR place service-account.json in the project root (never commit it!).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Master Owner (used by sync-users.ts) ─────────────────────────────────────
MASTER_OWNER_EMAIL=owner@yourdomain.com

# ─── App ──────────────────────────────────────────────────────────────────────
# The public URL of this deployment (used for password reset callback links).
APP_URL="https://yourdomain.com"

# ─── Vercel Cron Security ─────────────────────────────────────────────────────
# Set a long random string. Pass it as Authorization: Bearer <token> in cron calls.
CRON_SECRET=

# ─── SERPAPI (used by Video Automation Pipeline for trend research) ───────────
SERPAPI_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# VIDEO AUTOMATION PIPELINE — Next Creatives Studio
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
# Used for: AI title generation (research) + 60s video scriptwriting
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=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

# ─── HeyGen (AI Avatar Video Generation) ─────────────────────────────────────
# API key at: https://app.heygen.com/settings?nav=API
HEYGEN_API_KEY=sk_V2_hgu_k1fUjjTckta_Bw4IsmtrJLlTzB0wpHX2DxY7dPFjj3nF
# Avatar ID: HeyGen > Avatars > click your avatar > copy ID from the URL
HEYGEN_AVATAR_ID=90df258d2f2243d582cbe9cd4a8ec890
# Voice ID: Call GET https://api.heygen.com/v2/voices with your API key
#            and pick a Brazilian Portuguese voice (e.g. language: pt)
HEYGEN_VOICE_ID=

# ─── Submagic (Captions, B-rolls, Transitions) ────────────────────────────────
# API key at: https://app.submagic.co/settings (API section)
SUBMAGIC_API_KEY=sk-1e17a51d8bd1ce93714bb5f311c35c288c2e44f515dbef1feac92668f0ae91c2
# Optional: override base URL if Submagic changes their API domain
# SUBMAGIC_API_BASE_URL=https://api.submagic.co

# ─── YouTube Data API v3 (OAuth2 with Refresh Token) ─────────────────────────
# Step 1: Google Cloud Console → Enable "YouTube Data API v3"
# Step 2: Create OAuth2 credentials (Desktop app type) → copy Client ID & Secret
# Step 3: Get refresh token via OAuth Playground:
#          https://developers.google.com/oauthplayground
#          Scope: https://www.googleapis.com/auth/youtube.upload
#          → Authorize → Exchange code → copy "Refresh token"
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Optional: your channel ID for logging/verification
# Found at: https://www.youtube.com/account_advanced
YOUTUBE_CHANNEL_ID=

# ─── Pipeline Logging ─────────────────────────────────────────────────────────
# Set to 'debug' to see verbose step-by-step logs in the terminal
LOG_LEVEL=info
